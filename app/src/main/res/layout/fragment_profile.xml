<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/profile_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:menu="@menu/menu_profile"
        app:title="@string/profile_title"
        app:titleTextColor="@color/green" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="88dp">

            <!-- Header: cover + overlapping avatar (social / travel profile) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_cover_height">

                        <ImageView
                            android:id="@+id/profile_cover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_cover" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_profile_cover_fade_bottom" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/profile_header_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/white"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingTop="@dimen/profile_avatar_overlap_padding"
                        android:paddingEnd="24dp"
                        android:paddingBottom="20dp">

                        <TextView
                            android:id="@+id/username_profile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/sf_pro_display_regular"
                            android:gravity="center"
                            android:letterSpacing="0.01"
                            android:textColor="@color/role_text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            tools:text="Ayşe Yılmaz" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_change_photo_label"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:minHeight="36dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="@string/profile_change_photo"
                            android:textAllCaps="false"
                            android:textColor="@color/role_text_muted"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_camera_green"
                            app:iconGravity="textStart"
                            app:iconPadding="6dp"
                            app:iconSize="18dp"
                            app:iconTint="@color/green"
                            app:rippleColor="@color/home_ripple" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/profile_avatar_container"
                    android:layout_width="@dimen/profile_avatar_size"
                    android:layout_height="@dimen/profile_avatar_size"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/profile_avatar_margin_top"
                    android:clipChildren="false"
                    android:elevation="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="64dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/white"
                        app:strokeWidth="5dp">

                        <com.mikhaellopez.circularimageview.CircularImageView
                            android:id="@+id/profile_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="5dp"
                            android:src="@drawable/default_user"
                            app:civ_border_color="@color/white"
                            app:civ_border_width="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <ImageButton
                        android:id="@+id/btn_change_photo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_avatar_camera_btn"
                        android:contentDescription="@string/profile_change_photo"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_camera_green" />
                </FrameLayout>
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:text="@string/profile_email_label"
                        android:textColor="@color/role_text_muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/email_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:drawablePadding="10dp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:gravity="center_vertical"
                        android:textColor="@color/role_text_primary"
                        android:textSize="16sp"
                        app:drawableStartCompat="@drawable/email"
                        tools:text="ornek@email.com" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:text="@string/profile_my_comments"
                android:textColor="@color/green"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:text="@string/profile_my_comments_subtitle"
                android:textColor="@color/role_text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/profile_comments_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:gravity="center"
                android:padding="20dp"
                android:text="@string/profile_comments_empty"
                android:textColor="@color/role_text_muted"
                android:visibility="gone"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_my_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="20dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="2"
                tools:listitem="@layout/item_user_comment" />

            <ProgressBar
                android:id="@+id/profile_photo_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/green"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
