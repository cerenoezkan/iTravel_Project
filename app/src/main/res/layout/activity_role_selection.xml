<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/role_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_role_hero"
    android:fitsSystemWindows="true"
    tools:context=".RoleSelectionActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/role_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minHeight="520dp"
            android:paddingStart="22dp"
            android:paddingTop="8dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/role_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:letterSpacing="0.08"
                android:text="@string/role_brand_title"
                android:textAllCaps="false"
                android:textColor="@color/role_cream"
                android:textSize="42sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="iTravel" />

            <TextView
                android:id="@+id/role_slogan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/sf_pro_display_regular"
                android:gravity="center"
                android:lineSpacingMultiplier="1.25"
                android:text="@string/role_slogan"
                android:textColor="@color/role_on_dark_secondary"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/role_brand"
                tools:text="Yeni yerler keşfetmeye hazır mısın?" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/role_logo_card"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#28FFFFFF"
                app:cardCornerRadius="66dp"
                app:cardElevation="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/role_slogan"
                app:strokeColor="#55FFFFFF"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_role_logo_ring"
                    android:padding="18dp">

                    <ImageView
                        android:id="@+id/role_plane"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/role_logo_content_desc"
                        android:scaleType="fitCenter"
                        android:src="@drawable/plane"
                        android:tint="@color/role_cream" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/role_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:alpha="0.9"
                android:fontFamily="@font/sf_pro_display_regular"
                android:gravity="center"
                android:text="@string/role_footer_hint"
                android:textColor="@color/role_on_dark_secondary"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/role_logo_card" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/role_actions_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/role_surface_glass"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/role_hint"
                app:layout_constraintVertical_bias="1"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="22dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_user_login"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:elevation="6dp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:letterSpacing="0.03"
                        android:text="@string/role_user_login"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/role_primary_cta"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_role_user_24"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconTint="@color/white"
                        app:rippleColor="#66FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_admin_login"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:letterSpacing="0.02"
                        android:text="@string/role_admin_login"
                        android:textAllCaps="false"
                        android:textColor="@color/role_cream"
                        android:textSize="15sp"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_role_admin_24"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconTint="@color/role_cream"
                        app:rippleColor="#33FFFFFF"
                        app:strokeColor="@color/role_outline_light"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
