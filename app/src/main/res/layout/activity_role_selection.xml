<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/role_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/role_krem"
    android:fitsSystemWindows="false"
    tools:context=".RoleSelectionActivity">

    <ImageView
        android:id="@+id/role_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/role_hero_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/role_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="640dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/role_actions_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/role_surface_glass"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="1"
                app:strokeColor="@color/role_card_stroke"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="22dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="20dp">

                    <FrameLayout
                        android:id="@+id/role_card_icon_wrap"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_role_travel_icon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_role_travel_24" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/role_card_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:text="@string/role_card_title"
                        android:textColor="@color/role_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/role_card_icon_wrap"
                        app:layout_constraintTop_toTopOf="@id/role_card_icon_wrap" />

                    <TextView
                        android:id="@+id/role_card_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:text="@string/role_card_subtitle"
                        android:textColor="@color/role_text_muted"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/role_card_icon_wrap"
                        app:layout_constraintTop_toBottomOf="@id/role_card_title" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_user_login"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:clickable="true"
                        android:contentDescription="@string/role_user_login"
                        android:focusable="true"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/role_card_icon_wrap"
                        app:rippleColor="#44FFFFFF"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_role_primary_button"
                            android:paddingStart="18dp"
                            android:paddingEnd="16dp">

                            <ImageView
                                android:id="@+id/btn_user_icon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:importantForAccessibility="no"
                                android:src="@drawable/ic_role_user_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white" />

                            <TextView
                                android:id="@+id/btn_user_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="8dp"
                                android:fontFamily="@font/sf_pro_display_regular"
                                android:text="@string/role_user_login"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@id/btn_user_arrow"
                                app:layout_constraintStart_toEndOf="@id/btn_user_icon"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/btn_user_arrow"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:importantForAccessibility="no"
                                android:src="@drawable/ic_role_arrow_forward_white"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_admin_login"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:contentDescription="@string/role_admin_login"
                        android:focusable="true"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btn_user_login"
                        app:rippleColor="#2214502E"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_role_outline_button"
                            android:paddingStart="18dp"
                            android:paddingEnd="16dp">

                            <ImageView
                                android:id="@+id/btn_admin_icon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:importantForAccessibility="no"
                                android:src="@drawable/ic_role_settings_green"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/btn_admin_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="8dp"
                                android:fontFamily="@font/sf_pro_display_regular"
                                android:text="@string/role_admin_login"
                                android:textColor="@color/role_green_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@id/btn_admin_arrow"
                                app:layout_constraintStart_toEndOf="@id/btn_admin_icon"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/btn_admin_arrow"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:importantForAccessibility="no"
                                android:src="@drawable/ic_role_arrow_forward_green"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <ImageView
                        android:id="@+id/role_skyline"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginTop="18dp"
                        android:alpha="0.35"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:scaleType="fitXY"
                        android:src="@drawable/ic_role_skyline"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btn_admin_login" />

                    <ImageView
                        android:id="@+id/role_trust_icon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="10dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_role_shield_16"
                        app:layout_constraintEnd_toStartOf="@id/role_trust_text"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/role_skyline"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/role_trust_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/sf_pro_display_regular"
                        android:gravity="center"
                        android:text="@string/role_trust_footer"
                        android:textColor="@color/role_text_muted"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@id/role_trust_icon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/role_trust_icon"
                        app:layout_constraintTop_toTopOf="@id/role_trust_icon" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
