<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:clickable="true"
    android:focusable="true"
    android:stateListAnimator="@animator/card_lift"
    app:cardBackgroundColor="@color/home_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    app:rippleColor="@color/home_ripple"
    app:strokeColor="#1A14502E"
    app:strokeWidth="0.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="88dp"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:id="@+id/category_thumb_wrap"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/bg_category_thumb_stroke"
            android:padding="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/category_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImage"
                tools:src="@drawable/cat_tarihi" />
        </FrameLayout>

        <TextView
            android:id="@+id/category_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/sf_pro_display_regular"
            android:maxLines="1"
            android:textColor="@color/role_text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/category_desc"
            app:layout_constraintEnd_toStartOf="@id/btn_map_category"
            app:layout_constraintStart_toEndOf="@id/category_thumb_wrap"
            app:layout_constraintTop_toTopOf="@id/category_thumb_wrap"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Tarihi Yerler" />

        <TextView
            android:id="@+id/category_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/sf_pro_display_regular"
            android:maxLines="2"
            android:textColor="@color/role_text_muted"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/category_thumb_wrap"
            app:layout_constraintEnd_toStartOf="@id/btn_map_category"
            app:layout_constraintStart_toEndOf="@id/category_thumb_wrap"
            app:layout_constraintTop_toBottomOf="@id/category_title"
            tools:text="Ayasofya, Topkapı ve daha fazlası" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_map_category"
            style="@style/Widget.App.Home.MapButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="112dp"
            android:text="@string/view_on_map"
            app:icon="@drawable/ic_map_pin_green"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
