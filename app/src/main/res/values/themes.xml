<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#1A14502E</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.Itravel" parent="Theme.Material3.Light.NoActionBar">

        <item name="colorPrimary">@color/green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/green</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Widget.App.CommentRatingBar" parent="Widget.AppCompat.RatingBar.Small">
        <item name="colorControlActivated">@color/green</item>
        <item name="android:progressTint">@color/green</item>
        <item name="android:secondaryProgressTint">@color/nav_unselected</item>
        <item name="android:progressBackgroundTint">@color/nav_unselected</item>
    </style>

    <style name="LabelStyle">
        <item name="android:background">@drawable/bg_label</item>
        <item name="android:textColor">#FFF</item>
    </style>
</resources>